---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/landing/FaqSection.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import LandingHeader from '../components/landing/LandingHeader.astro';
import ValueSections from '../components/landing/ValueSections.astro';

const primaryCtaClass =
  'inline-flex items-center justify-center rounded-2xl bg-[color:var(--brand)] px-5 py-3 text-sm font-semibold text-white shadow-[0_16px_32px_rgba(37,99,235,0.22)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[color:var(--brand-strong)]';
const secondaryCtaClass =
  'inline-flex items-center justify-center rounded-2xl border border-[color:var(--line)] bg-white px-5 py-3 text-sm font-semibold text-[color:var(--ink)] transition-colors hover:bg-slate-50';

const upcomingModules = [
  { title: 'Punto de venta (POS)', desc: 'Venta y operación en mostrador sobre el mismo inventario.' },
  { title: 'Fabricación', desc: 'Planeación y control de producción basado en variantes.' },
  { title: 'Tienda online', desc: 'Publica tu catálogo en tu propia tienda.' },
  { title: 'Marketplace', desc: 'Habilita el canal marketplace sin duplicar catálogo.' },
  { title: 'Integraciones', desc: 'Conecta envíos, marketplaces y herramientas externas.' },
];

const implementationPoints = [
  {
    title: 'Arranque rápido',
    desc: 'Empieza con catálogo, variantes y almacenes sin pasar semanas configurando un ERP completo.',
  },
  {
    title: 'Operación ordenada',
    desc: 'Cada movimiento deja rastro para que ventas, stock y expansión trabajen sobre el mismo dato.',
  },
  {
    title: 'Escalado sin rehacer',
    desc: 'Cuando actives POS, fabricación o ecommerce, la base ya está construida sobre el mismo núcleo.',
  },
];

const faqs = [
  {
    q: '¿Qué incluye el Plan Inicial de $199 MXN al mes?',
    a: 'Incluye inventario con variantes, control por almacén, movimientos auditables, POS para descontar inventario correctamente, códigos de barras y flujo de empaque validado.',
  },
  {
    q: '¿El POS ya viene incluido?',
    a: 'Sí. El Plan Inicial ya incluye POS para registrar ventas y reducir inventario sobre la misma base de datos.',
  },
  {
    q: '¿Me sirve si vendo en tienda y ecommerce?',
    a: 'Sí. Nexuit está pensado para operaciones con inventario físico que venden en tienda, ecommerce o ambos, sin depender de hojas de cálculo ni plugins desconectados.',
  },
  {
    q: '¿Puedo pagar anual?',
    a: 'Sí. También puedes elegir el plan anual por $1,990 MXN al año, con un ahorro equivalente a 2 meses frente al pago mensual.',
  },
];
---

<BaseLayout
  title="Nexuit — Inventario y POS desde $199 MXN/mes"
  description="Ordena tu inventario físico con variantes, almacenes y POS. Evita sobreventa y errores. Plan inicial $199 MXN/mes con garantía de 7 días."
  path="/"
>
  <LandingHeader />
  <HeroSection primaryCtaClass={primaryCtaClass} secondaryCtaClass={secondaryCtaClass} />
  <ValueSections
    primaryCtaClass={primaryCtaClass}
    implementationPoints={implementationPoints}
    upcomingModules={upcomingModules}
  />
  <section id="plan" class="mx-auto max-w-6xl scroll-mt-28 px-4 py-14">
    <div class="rounded-[2rem] border border-[rgba(255,255,255,0.1)] bg-[linear-gradient(135deg,#eff6ff_0%,#ffffff_38%,#eef2ff_100%)] p-8 shadow-[0_22px_50px_rgba(15,23,42,0.1)]">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--brand)]">
        Plan Inicial
      </div>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[color:var(--ink)] md:text-4xl">
        Plan Inicial
      </h2>
      <div class="mt-5 text-4xl font-semibold tracking-tight text-[color:var(--ink)] md:text-5xl">
        $199 MXN / mes
      </div>
      <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
        Usado en producción sin sobreventa.
      </p>
      <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
        Ideal para fabricantes y vendedores con inventario físico.
      </p>
      <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
        Anual: $1,990 MXN / año (ahorras 2 meses)
      </p>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">
            Inventario con variantes reales (tallas, colores, etc.)
          </div>
        </div>
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">Control por almacén</div>
        </div>
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">Movimientos auditables</div>
        </div>
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">
            POS para reducir inventario correctamente
          </div>
        </div>
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">Códigos de barras e impresión</div>
        </div>
        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-sm leading-7 text-[color:var(--ink)]">Flujo de empaque validado</div>
        </div>
      </div>

      <p class="mt-6 text-sm leading-7 text-[color:var(--muted)]">
        Garantía de 7 días. Sin riesgo: si no te funciona, te devolvemos tu dinero.
      </p>
      <div class="mt-6">
        <a href="/signup" data-cta="pricing-create-account" class={primaryCtaClass}>
          Empezar por $199 MXN
        </a>
      </div>
    </div>
  </section>
  <FaqSection
    primaryCtaClass={primaryCtaClass}
    secondaryCtaClass={secondaryCtaClass}
    faqs={faqs}
  />
  <LandingFooter />
</BaseLayout>
