---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/landing/FaqSection.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import LandingHeader from '../components/landing/LandingHeader.astro';
import ValueSections from '../components/landing/ValueSections.astro';

const primaryCtaClass =
  'inline-flex items-center justify-center rounded-2xl bg-[color:var(--brand)] px-5 py-3 text-sm font-semibold text-white shadow-[0_16px_32px_rgba(37,99,235,0.22)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[color:var(--brand-strong)]';
const secondaryCtaClass =
  'inline-flex items-center justify-center rounded-2xl border border-[color:var(--line)] bg-white px-5 py-3 text-sm font-semibold text-[color:var(--ink)] transition-colors hover:bg-slate-50';

const registerUrl = 'https://app.nexuit.com/register';
const loginUrl = 'https://app.nexuit.com/login';

type ModuleTone = 'available' | 'strategic' | 'capacity';

interface ModuleCard {
  title: string;
  desc: string;
  status: string;
  tone: ModuleTone;
}

const moduleCards: ModuleCard[] = [
  {
    title: 'Catálogo',
    desc: 'Productos, variantes, SKUs y clasificación comercial listos para operar.',
    status: 'Disponible',
    tone: 'available',
  },
  {
    title: 'Inventario',
    desc: 'Stock visible por sucursal, almacén y ubicación interna.',
    status: 'Disponible',
    tone: 'available',
  },
  {
    title: 'Punto de venta (POS)',
    desc: 'Operación de mostrador conectada al inventario y al contexto de stock.',
    status: 'Disponible',
    tone: 'available',
  },
  {
    title: 'Despachos',
    desc: 'Picking, packing y envío conectados a cada venta.',
    status: 'Disponible',
    tone: 'available',
  },
  {
    title: 'Tienda online',
    desc: 'Dirección estratégica, pensada para que el comercio digital use el mismo catálogo, variantes y stock.',
    status: 'Dirección estratégica',
    tone: 'strategic',
  },
  {
    title: 'Compras y fabricación',
    desc: 'Abastecimiento, proveedores y producción para negocios que ensamblan, transforman o fabrican.',
    status: 'Por capacidades',
    tone: 'capacity',
  },
];

const implementationPoints = [
  {
    title: 'Arranque rápido',
    desc: 'Crea empresa, catálogo, sucursales y almacenes con una estructura mínima clara.',
  },
  {
    title: 'Operación conectada',
    desc: 'Cada venta y movimiento conserva stock, sucursal, almacén y salida operativa.',
  },
  {
    title: 'Crecimiento modular',
    desc: 'Activa más capacidades cuando tu operación pida compras, fabricación o comercio digital.',
  },
];

const faqs = [
  {
    q: '¿Qué es Nexuit?',
    a: 'Nexuit es una suite SaaS para ordenar inventario, ventas físicas, POS, ventas online y operación en negocios con productos, sucursales y almacenes.',
  },
  {
    q: '¿El POS está disponible?',
    a: 'Sí. POS se presenta como disponible para operación de mostrador, conectado al mismo inventario y contexto de stock.',
  },
  {
    q: '¿La tienda online ya se publica automáticamente?',
    a: 'No se comunica como publicación automática cerrada. Nexuit la presenta como dirección estratégica: comercio digital pensado para nacer del mismo catálogo y preparado para evolucionar sobre el stock operativo.',
  },
  {
    q: '¿Tengo que activar todo desde el primer día?',
    a: 'No. Nexuit se organiza por capacidades para que empieces con una base operativa clara y actives más módulos conforme tu negocio crece.',
  },
];
---

<BaseLayout
  title="Nexuit — Inventario, ventas y operación multicanal"
  description="Suite SaaS para ordenar productos, sucursales, almacenes, POS, ventas online y despachos sobre el mismo inventario operativo."
  path="/"
>
  <LandingHeader registerUrl={registerUrl} loginUrl={loginUrl} />
  <HeroSection
    primaryCtaClass={primaryCtaClass}
    secondaryCtaClass={secondaryCtaClass}
    registerUrl={registerUrl}
    loginUrl={loginUrl}
  />
  <ValueSections
    primaryCtaClass={primaryCtaClass}
    secondaryCtaClass={secondaryCtaClass}
    registerUrl={registerUrl}
    loginUrl={loginUrl}
    implementationPoints={implementationPoints}
    moduleCards={moduleCards}
  />
  <section id="plan" class="mx-auto max-w-6xl scroll-mt-28 px-4 py-14">
    <div class="rounded-[2rem] border border-[rgba(255,255,255,0.1)] bg-[linear-gradient(135deg,#eff6ff_0%,#ffffff_42%,#eef2ff_100%)] p-8 shadow-[0_22px_50px_rgba(15,23,42,0.1)]">
      <div class="grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-start">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--brand)]">
            Planes y capacidades
          </div>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[color:var(--ink)] md:text-4xl">
            Empieza con una base operativa clara
          </h2>
          <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
            Nexuit se activa por capacidades. Tu negocio puede empezar con inventario, catálogo,
            POS y salidas, y crecer hacia más módulos cuando sea momento.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href={registerUrl} data-cta="pricing-create-company" class={primaryCtaClass}>
              Crear empresa
            </a>
            <a href={loginUrl} data-cta="pricing-login" class={secondaryCtaClass}>
              Iniciar sesión
            </a>
          </div>
        </div>

        <div class="glass-card rounded-[1.75rem] p-6">
          <div class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--brand)]">Plan inicial</div>
          <div class="mt-3 text-3xl font-semibold tracking-tight text-[color:var(--ink)]">
            Desde $199 MXN / mes
          </div>
          <p class="mt-2 text-sm leading-7 text-[color:var(--muted)]">
            Anual: $1,990 MXN / año.
          </p>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-[1.25rem] border border-[color:var(--line)] bg-white/80 p-4 text-sm leading-7 text-[color:var(--ink)]">
              Catálogo, variantes y SKUs.
            </div>
            <div class="rounded-[1.25rem] border border-[color:var(--line)] bg-white/80 p-4 text-sm leading-7 text-[color:var(--ink)]">
              Stock por sucursal, almacén y ubicación.
            </div>
            <div class="rounded-[1.25rem] border border-[color:var(--line)] bg-white/80 p-4 text-sm leading-7 text-[color:var(--ink)]">
              POS disponible sobre el mismo inventario.
            </div>
            <div class="rounded-[1.25rem] border border-[color:var(--line)] bg-white/80 p-4 text-sm leading-7 text-[color:var(--ink)]">
              Salidas, empaque y despachos con contexto.
            </div>
          </div>

          <p class="mt-5 text-sm leading-7 text-[color:var(--muted)]">
            La tienda online se presenta como dirección estratégica del producto, preparada para
            evolucionar sin prometer publicación automática cerrada dentro del plan.
          </p>
        </div>
      </div>
    </div>
  </section>
  <FaqSection
    primaryCtaClass={primaryCtaClass}
    secondaryCtaClass={secondaryCtaClass}
    registerUrl={registerUrl}
    loginUrl={loginUrl}
    faqs={faqs}
  />
  <LandingFooter />
</BaseLayout>
