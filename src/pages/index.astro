---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/landing/FaqSection.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import LandingHeader from '../components/landing/LandingHeader.astro';
import ValueSections from '../components/landing/ValueSections.astro';

const PRIMARY_CTA_LABEL = 'Probar 7 días gratis';
const primaryCtaHref = 'https://app.nexuit.com/register';
const loginUrl = 'https://app.nexuit.com/login';
const ctaMicrocopy = 'Plan más completo · Sin tarjeta · Luego eliges tu plan';

const navItems = [
  { label: 'Producto', href: '#producto' },
  { label: 'Operación', href: '#operacion' },
  { label: 'Planes', href: '#planes' },
  { label: 'Para quién', href: '#para-quien' },
  { label: 'FAQ', href: '#faq' },
];

const heroChips = [
  'Stock por sucursal',
  'Ventas conectadas',
  'Empaque validado',
  'Conciliación de inventario',
];

const problemCards = [
  {
    title: 'Stock descuadrado',
    desc: 'El sistema dice una cosa y el conteo físico otra.',
    icon: 'warning',
  },
  {
    title: 'Pedidos mal empacados',
    desc: 'Productos incompletos o equivocados salen sin control.',
    icon: 'box',
  },
  {
    title: 'Diferencias sin explicación',
    desc: 'No sabes si viene de venta, salida, ajuste, traslado o empaque.',
    icon: 'shield',
  },
] as const;

const operationSteps = [
  { title: 'Catálogo', desc: 'Productos, variantes y códigos.', icon: 'catalog' },
  { title: 'Stock', desc: 'Existencias por sucursal o almacén.', icon: 'warehouse' },
  { title: 'Venta', desc: 'Cada venta descuenta inventario.', icon: 'movement' },
  { title: 'Organización', desc: 'Pedidos listos para preparar.', icon: 'layers' },
  { title: 'Empaque', desc: 'Validación antes de entregar.', icon: 'box' },
  { title: 'Conciliación', desc: 'Compara y explica diferencias.', icon: 'check' },
] as const;

const reconciliationRows = [
  { product: 'Auriculares Bluetooth', system: '120', physical: '116', diff: '-4', status: 'Revisar', tone: 'danger' },
  { product: 'Mouse Inalámbrico', system: '80', physical: '80', diff: '0', status: 'Cuadrado', tone: 'success' },
  { product: 'Teclado Mecánico', system: '45', physical: '47', diff: '+2', status: 'Sobrante', tone: 'info' },
  { product: 'Monitor 24”', system: '30', physical: '28', diff: '-2', status: 'Revisar', tone: 'danger' },
  { product: 'Webcam HD', system: '15', physical: '15', diff: '0', status: 'Cuadrado', tone: 'success' },
] as const;

const reconciliationBenefits = [
  { title: 'Conteos físicos por ubicación', icon: 'layers' },
  { title: 'Historial de movimientos', icon: 'movement' },
  { title: 'Ajustes controlados', icon: 'check' },
  { title: 'Trazabilidad total', icon: 'shield' },
] as const;

const deviceBullets = [
  {
    title: 'Desktop',
    desc: 'Reportes, configuración, catálogo, conciliaciones y más.',
    icon: 'desktop',
  },
  {
    title: 'Móvil',
    desc: 'Conteos, ventas, organización de pedidos, empaque y salidas en segundos.',
    icon: 'phone',
  },
] as const;

const packingItems = [
  { item: 'Playera Negra M', status: 'validado' },
  { item: 'Gorra Azul', status: 'validado' },
  { item: 'Tenis Blanco', status: 'validado' },
  { item: 'Tenis Blanco 27', status: 'pendiente' },
] as const;

const plans = [
  {
    name: 'Base',
    desc: 'Para negocios que quieren ordenar productos y stock.',
    price: 'Desde $199 MXN / mes',
    icon: 'catalog',
    features: [
      'Catálogo',
      'Inventario',
      'Stock por sucursal',
      'Movimientos básicos',
      'Acceso desde móvil',
    ],
  },
  {
    name: 'Operativo',
    desc: 'Para negocios que venden y preparan pedidos.',
    price: 'Desde $399 MXN / mes',
    icon: 'movement',
    features: [
      'Todo lo de Base',
      'Ventas y salidas',
      'Organización de pedidos',
      'Empaque validado',
      'Historial de movimientos',
      'Usuarios operativos',
    ],
  },
  {
    name: 'Multicanal',
    desc: 'Para negocios con varias sucursales o canales.',
    price: 'Desde $699 MXN / mes',
    icon: 'store',
    features: [
      'Todo lo de Operativo',
      'Múltiples ubicaciones',
      'Canales de venta',
      'Reglas por sucursal',
      'Despachos',
      'Reportes operativos',
    ],
  },
  {
    name: 'Completo',
    badge: 'Incluido en la prueba gratis',
    desc: 'Para operaciones que necesitan máximo control y trazabilidad.',
    price: 'Desde $1,199 MXN / mes',
    icon: 'shield',
    highlighted: true,
    features: [
      'Todo lo de Multicanal',
      'Conciliación avanzada',
      'Conteos físicos',
      'Ajustes controlados',
      'Compras y fabricación',
      'Alertas de diferencias',
      'Auditoría operativa',
    ],
  },
] as const;

const audienceCards = [
  {
    title: 'Tiendas y retail',
    desc: 'Control de stock, ventas y reposiciones.',
    icon: 'store',
  },
  {
    title: 'Marcas multicanal',
    desc: 'Vende en varios canales sin perder visibilidad.',
    icon: 'layers',
  },
  {
    title: 'Almacenes y distribución',
    desc: 'Múltiples ubicaciones, traslados y despachos.',
    icon: 'truck',
  },
  {
    title: 'Empaque y fulfillment',
    desc: 'Organiza, valida y despacha sin errores.',
    icon: 'box',
  },
] as const;

const faqs = [
  {
    q: '¿Qué plan incluye la prueba gratis?',
    a: 'La prueba gratuita incluye el plan más completo de Nexuit durante 7 días.',
  },
  {
    q: '¿Necesito tarjeta para empezar?',
    a: 'No. Puedes probar el plan más completo por 7 días sin ingresar tarjeta.',
  },
  {
    q: '¿Qué pasa cuando termina la prueba?',
    a: 'Puedes elegir uno de los 4 planes disponibles según las capacidades que necesite tu operación.',
  },
  {
    q: '¿Puedo cambiar de plan después?',
    a: 'Sí. Puedes iniciar con un plan y escalar cuando necesites más módulos, sucursales, conciliación o capacidades avanzadas.',
  },
  {
    q: '¿Pierdo mi información si cambio de plan?',
    a: 'No. Tu información operativa se conserva; el plan define las capacidades disponibles.',
  },
];
---

<BaseLayout
  title="Nexuit | Inventario, ventas, empaque y conciliación"
  description="Controla stock, ventas, organización, empaque y conciliación de inventario desde una sola base. Prueba el plan más completo de Nexuit por 7 días, sin tarjeta."
  path="/"
>
  <LandingHeader
    navItems={navItems}
    primaryCtaHref={primaryCtaHref}
    primaryCtaLabel={PRIMARY_CTA_LABEL}
    loginUrl={loginUrl}
  />
  <main>
    <HeroSection
      chips={heroChips}
      primaryCtaHref={primaryCtaHref}
      primaryCtaLabel={PRIMARY_CTA_LABEL}
      ctaMicrocopy={ctaMicrocopy}
    />
    <ValueSections
      problemCards={problemCards}
      operationSteps={operationSteps}
      reconciliationRows={reconciliationRows}
      reconciliationBenefits={reconciliationBenefits}
      deviceBullets={deviceBullets}
      packingItems={packingItems}
      plans={plans}
      audienceCards={audienceCards}
      primaryCtaHref={primaryCtaHref}
      primaryCtaLabel={PRIMARY_CTA_LABEL}
      ctaMicrocopy={ctaMicrocopy}
    />
    <FaqSection
      faqs={faqs}
      primaryCtaHref={primaryCtaHref}
      primaryCtaLabel={PRIMARY_CTA_LABEL}
      ctaMicrocopy={ctaMicrocopy}
    />
  </main>
  <LandingFooter navItems={navItems} />
</BaseLayout>
