---
import IconGlyph from './IconGlyph.astro';

interface TextCard {
  title: string;
  desc: string;
  icon: 'warning' | 'box' | 'shield' | 'store' | 'truck' | 'layers' | 'desktop' | 'phone';
}

interface StepItem {
  title: string;
  desc: string;
  icon: 'catalog' | 'warehouse' | 'movement' | 'layers' | 'box' | 'check';
}

interface ReconciliationRow {
  product: string;
  system: string;
  physical: string;
  diff: string;
  status: string;
  tone: 'danger' | 'success' | 'info';
}

interface Benefit {
  title: string;
  icon: 'layers' | 'movement' | 'check' | 'shield';
}

interface DeviceBullet {
  title: string;
  desc: string;
  icon: 'desktop' | 'phone';
}

interface PackingItem {
  item: string;
  status: 'validado' | 'pendiente';
}

interface Plan {
  name: string;
  desc: string;
  price: string;
  features: string[];
  highlighted?: boolean;
  badge?: string;
  icon: 'catalog' | 'movement' | 'store' | 'shield';
}

interface AudienceCard extends TextCard {}

interface Props {
  problemCards: TextCard[];
  operationSteps: StepItem[];
  reconciliationRows: ReconciliationRow[];
  reconciliationBenefits: Benefit[];
  deviceBullets: DeviceBullet[];
  packingItems: PackingItem[];
  plans: Plan[];
  audienceCards: AudienceCard[];
  primaryCtaHref: string;
  primaryCtaLabel: string;
  ctaMicrocopy: string;
}

const {
  problemCards,
  operationSteps,
  reconciliationRows,
  reconciliationBenefits,
  deviceBullets,
  packingItems,
  plans,
  audienceCards,
  primaryCtaHref,
  primaryCtaLabel,
  ctaMicrocopy,
} = Astro.props;

const statusClasses = {
  danger: 'bg-orange-50 text-orange-700',
  success: 'bg-emerald-50 text-emerald-700',
  info: 'bg-blue-50 text-blue-700',
} as const;
---

<section id="producto" class="section-band scroll-mt-28 border-y">
  <div class="mx-auto max-w-[1240px] px-4 py-14 md:px-6 md:py-18">
    <div class="grid gap-8 lg:grid-cols-[0.7fr_1.3fr] lg:items-center">
      <div>
        <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">El problema</div>
        <h2 class="mt-3 max-w-lg text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
          Cuando el inventario no cuadra, las pérdidas aparecen tarde.
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {problemCards.map((card) => (
          <article class="glass-card-strong rounded-[1.75rem] p-6">
            <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-2xl bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)]">
              <IconGlyph name={card.icon} />
            </div>
            <h3 class="text-lg font-black text-[color:var(--ink)]">{card.title}</h3>
            <p class="mt-3 text-[15px] leading-7 text-[color:var(--muted)]">{card.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<section id="operacion" class="mx-auto max-w-[1240px] scroll-mt-28 px-4 py-14 md:px-6 md:py-18">
  <div class="grid gap-8 lg:grid-cols-[0.62fr_1.38fr] lg:items-center">
    <div>
      <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Tu operación, conectada</div>
      <h2 class="mt-3 max-w-lg text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
        Del stock al empaque, cada movimiento queda conectado.
      </h2>
    </div>

    <div class="grid gap-3 md:grid-cols-6 md:items-start">
      {operationSteps.map((step, index) => (
        <div class="relative">
          <article class="glass-card rounded-[1.5rem] p-4 text-center md:min-h-[10.5rem]">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-[color:var(--line)] bg-white text-[color:var(--brand)] shadow-[0_12px_26px_rgba(11,92,255,0.1)]">
              <IconGlyph name={step.icon} class="h-6 w-6" />
            </div>
            <div class="mt-4 text-sm font-black text-[color:var(--ink)]">{index + 1}. {step.title}</div>
            <p class="mt-2 text-xs leading-5 text-[color:var(--muted)]">{step.desc}</p>
          </article>
          {index < operationSteps.length - 1 && (
            <div class="hidden md:block absolute left-[calc(100%-0.25rem)] top-14 z-10 text-xl font-black text-slate-400">→</div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section-band border-y">
  <div class="mx-auto grid max-w-[1240px] gap-10 px-4 py-14 md:px-6 md:py-18 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
    <div class="glass-card-strong overflow-hidden rounded-[2rem]">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-[color:var(--line)] px-5 py-4">
        <div class="text-sm font-black text-[color:var(--ink)]">Conciliación de inventario</div>
        <div class="rounded-xl border border-[color:var(--line)] bg-white px-3 py-1.5 text-xs font-bold text-[color:var(--muted)]">Almacén Norte</div>
      </div>
      <div class="grid gap-3 p-4 sm:hidden">
        {reconciliationRows.map((row) => (
          <article class="rounded-2xl border border-[color:var(--line)] bg-white p-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="font-black text-[color:var(--ink)]">{row.product}</div>
                <div class="mt-2 text-xs text-[color:var(--muted)]">Sistema {row.system} · Conteo {row.physical}</div>
              </div>
              <span class={`rounded-full px-2 py-1 text-[10px] font-bold ${statusClasses[row.tone]}`}>{row.status}</span>
            </div>
            <div class={`mt-3 text-sm font-black ${row.diff === '0' ? 'text-[color:var(--ink)]' : row.diff.startsWith('-') ? 'text-[color:var(--danger)]' : 'text-[color:var(--brand)]'}`}>
              Diferencia {row.diff}
            </div>
          </article>
        ))}
      </div>
      <div class="hidden overflow-x-auto sm:block">
        <table class="w-full min-w-[42rem] text-left text-sm">
          <thead class="text-xs font-bold uppercase tracking-[0.12em] text-[color:var(--muted)]">
            <tr class="border-b border-[color:var(--line)]">
              <th class="px-5 py-4">Producto</th>
              <th class="px-5 py-4">Sistema</th>
              <th class="px-5 py-4">Conteo físico</th>
              <th class="px-5 py-4">Diferencia</th>
              <th class="px-5 py-4">Estado</th>
            </tr>
          </thead>
          <tbody>
            {reconciliationRows.map((row) => (
              <tr class="border-b border-[color:var(--line)] last:border-b-0">
                <td class="px-5 py-4 font-semibold text-[color:var(--ink)]">{row.product}</td>
                <td class="px-5 py-4 text-[color:var(--ink)]">{row.system}</td>
                <td class="px-5 py-4 text-[color:var(--ink)]">{row.physical}</td>
                <td class={`px-5 py-4 font-black ${row.diff === '0' ? 'text-[color:var(--ink)]' : row.diff.startsWith('-') ? 'text-[color:var(--danger)]' : 'text-[color:var(--brand)]'}`}>{row.diff}</td>
                <td class="px-5 py-4">
                  <span class={`rounded-full px-3 py-1 text-xs font-bold ${statusClasses[row.tone]}`}>{row.status}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Conciliación que te da control</div>
      <h2 class="mt-3 text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
        Detecta diferencias antes de perder mercancía.
      </h2>
      <p class="mt-5 max-w-xl text-[16px] leading-8 text-[color:var(--muted)]">
        Compara conteos físicos contra ventas, salidas y movimientos. Encuentra faltantes, errores operativos o ajustes pendientes.
      </p>
      <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4">
        {reconciliationBenefits.map((benefit) => (
          <div>
            <div class="mb-3 flex h-11 w-11 items-center justify-center rounded-2xl border border-[color:var(--line)] bg-white text-[color:var(--brand)] shadow-[0_12px_26px_rgba(7,27,58,0.06)]">
              <IconGlyph name={benefit.icon} />
            </div>
            <div class="text-sm font-black leading-snug text-[color:var(--ink)]">{benefit.title}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-[1240px] px-4 py-14 md:px-6 md:py-18">
  <div class="grid min-w-0 gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-center">
    <div class="min-w-0">
      <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Supervisa y opera desde donde estés</div>
      <h2 class="mt-3 text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
        Todo tu negocio en desktop y móvil.
      </h2>
      <p class="mt-5 text-[16px] leading-8 text-[color:var(--muted)]">
        Administra, analiza y configura en desktop. Opera en piso, bodega o empaque desde tu móvil.
      </p>
      <div class="mt-8 grid gap-5">
        {deviceBullets.map((bullet) => (
          <div class="flex gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-[color:var(--line)] bg-white text-[color:var(--brand)] shadow-[0_12px_26px_rgba(7,27,58,0.06)]">
              <IconGlyph name={bullet.icon} />
            </div>
            <div>
              <div class="font-black text-[color:var(--ink)]">{bullet.title}</div>
              <p class="mt-1 text-sm leading-6 text-[color:var(--muted)]">{bullet.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative min-h-[28rem] min-w-0 overflow-hidden">
      <div class="absolute inset-x-6 bottom-3 h-16 rounded-full bg-[rgba(7,27,58,0.18)] blur-2xl"></div>
      <div class="relative mx-auto max-w-3xl">
        <div class="rounded-t-[1.6rem] border-[8px] border-[#151923] bg-white shadow-[0_28px_70px_rgba(7,27,58,0.18)] sm:border-[10px]">
          <div class="grid min-h-[19rem] grid-cols-[5.25rem_minmax(0,1fr)] overflow-hidden rounded-t-xl bg-white sm:grid-cols-[7rem_1fr]">
            <div class="bg-[color:var(--page-bg-soft)] p-3 text-[10px] text-[color:var(--muted)] sm:p-4 sm:text-xs">
              <div class="mb-4 h-2 w-14 rounded-full bg-[color:var(--brand)]"></div>
              {['Inventario', 'Ventas', 'Empaque', 'Conteos'].map((item) => (
                <div class="mb-3 rounded-lg bg-white px-2 py-2 font-semibold">{item}</div>
              ))}
            </div>
            <div class="min-w-0 p-3 sm:p-5">
              <div class="mb-4 flex items-center justify-between">
                <div class="min-w-0">
                  <div class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--brand)]">Inventario / conciliación</div>
                  <div class="mt-1 text-lg font-black text-[color:var(--ink)]">Productos con diferencia</div>
                </div>
                <div class="hidden rounded-xl bg-[color:var(--brand)] px-3 py-2 text-xs font-bold text-white sm:block">Nuevo conteo</div>
              </div>
              <div class="grid gap-2 text-xs">
                {['Auriculares Bluetooth', 'Mouse Inalámbrico', 'Teclado Mecánico', 'Monitor 24”'].map((item, index) => (
                  <div class="grid grid-cols-[minmax(0,1fr)_2rem_2rem_2.5rem] rounded-xl border border-[color:var(--line)] bg-white px-2 py-3 sm:grid-cols-[1fr_3rem_3rem_4rem] sm:px-3">
                    <span class="truncate font-semibold text-[color:var(--ink)]">{item}</span>
                    <span>{[120, 80, 45, 30][index]}</span>
                    <span>{[116, 80, 47, 28][index]}</span>
                    <span class={index === 1 ? 'font-bold text-[color:var(--success)]' : 'font-bold text-[color:var(--danger)]'}>
                      {['-4', '0', '+2', '-2'][index]}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        <div class="mx-auto h-4 max-w-[80%] rounded-b-[2rem] bg-[#0f172a] shadow-[0_18px_34px_rgba(7,27,58,0.18)]"></div>
      </div>

      <div class="relative z-10 mx-auto -mt-48 w-[15rem] rounded-[2.2rem] border-[10px] border-[#111827] bg-white p-4 shadow-[0_28px_70px_rgba(7,27,58,0.22)] sm:ml-auto sm:mr-8">
        <div class="flex items-center justify-between">
          <div>
            <div class="text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--brand)]">Empaque</div>
            <div class="mt-1 text-lg font-black text-[color:var(--ink)]">Pedido #1048</div>
          </div>
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)]">
            <IconGlyph name="box" />
          </div>
        </div>
        <div class="mt-5 grid gap-3">
          {packingItems.map((item) => (
            <div class="flex items-center justify-between rounded-2xl border border-[color:var(--line)] px-3 py-3">
              <span class="text-sm font-semibold text-[color:var(--ink)]">{item.item}</span>
              <span class={`text-xs font-black ${item.status === 'validado' ? 'text-[color:var(--success)]' : 'text-orange-500'}`}>
                {item.status === 'validado' ? '✓' : '!'}
              </span>
            </div>
          ))}
        </div>
        <p class="mt-4 rounded-2xl bg-[color:var(--page-bg-soft)] px-3 py-3 text-xs leading-5 text-[color:var(--muted)]">
          Faltan 1 producto por validar antes de despachar.
        </p>
        <div class="mt-3 rounded-2xl bg-[color:var(--brand)] px-4 py-3 text-center text-sm font-bold text-white">
          Marcar como completo
        </div>
      </div>
    </div>
  </div>
</section>

<section id="planes" class="section-band scroll-mt-28 border-y">
  <div class="mx-auto max-w-[1240px] px-4 py-14 md:px-6 md:py-18">
    <div class="mx-auto max-w-3xl text-center">
      <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Elige el nivel que necesita tu operación</div>
      <h2 class="mt-3 text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
        4 planes para crecer sin cambiar de sistema.
      </h2>
      <p class="mt-4 text-[16px] leading-8 text-[color:var(--muted)]">
        Empieza con 7 días gratis del plan más completo, sin tarjeta. Al terminar, elige el plan que mejor se adapte a tu negocio.
      </p>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {plans.map((plan) => (
        <article class={`relative flex flex-col rounded-[1.75rem] border bg-white p-6 shadow-[0_20px_48px_rgba(7,27,58,0.08)] ${plan.highlighted ? 'border-[color:var(--brand)] ring-2 ring-[rgba(11,92,255,0.08)]' : 'border-[color:var(--line)]'}`}>
          {plan.badge && (
            <div class="absolute -top-4 left-4 right-4 rounded-t-2xl bg-[color:var(--navy)] px-4 py-2 text-center text-xs font-bold text-white">
              {plan.badge}
            </div>
          )}
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)]">
            <IconGlyph name={plan.icon} />
          </div>
          <h3 class="mt-5 text-xl font-black text-[color:var(--ink)]">{plan.name}</h3>
          <p class="mt-2 min-h-[3rem] text-sm leading-6 text-[color:var(--muted)]">{plan.desc}</p>
          <ul class="mt-5 grid gap-2 text-sm text-[color:var(--ink)]">
            {plan.features.map((feature) => (
              <li class="flex gap-2">
                <span class="font-black text-[color:var(--brand)]">✓</span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-auto border-t border-[color:var(--line)] pt-5">
            <div class="text-xs font-semibold text-[color:var(--muted)]">Precio</div>
            <div class="mt-1 text-2xl font-black text-[color:var(--ink)]">{plan.price}</div>
          </div>
        </article>
      ))}
    </div>

    <div class="mx-auto mt-8 flex max-w-4xl flex-col items-center gap-4 rounded-[1.75rem] border border-[color:var(--line)] bg-white p-5 text-center shadow-[0_18px_42px_rgba(7,27,58,0.08)] md:flex-row md:justify-between md:text-left">
      <div class="flex items-center gap-4">
        <div class="hidden h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)] sm:flex">
          <IconGlyph name="gift" />
        </div>
        <div>
          <div class="font-black text-[color:var(--ink)]">Prueba el plan más completo por 7 días, sin tarjeta.</div>
          <p class="mt-1 text-sm text-[color:var(--muted)]">Luego elige el plan que necesita tu operación.</p>
        </div>
      </div>
      <div class="w-full md:w-auto">
        <a href={primaryCtaHref} data-cta="plans-trial" class="inline-flex w-full justify-center rounded-2xl bg-[color:var(--brand)] px-6 py-3 text-sm font-bold text-white shadow-[0_16px_30px_rgba(11,92,255,0.22)] md:w-auto">
          {primaryCtaLabel}
        </a>
        <div class="mt-2 text-center text-xs font-medium text-[color:var(--muted)]">{ctaMicrocopy}</div>
      </div>
    </div>
  </div>
</section>

<section id="para-quien" class="mx-auto max-w-[1240px] scroll-mt-28 px-4 py-14 md:px-6 md:py-18">
  <div class="mx-auto max-w-3xl text-center">
    <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Hecho para operaciones reales</div>
    <h2 class="mt-3 text-3xl font-black tracking-[-0.04em] text-[color:var(--ink)] md:text-5xl">
      Para negocios que mueven mercancía todos los días.
    </h2>
  </div>
  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    {audienceCards.map((card) => (
      <article class="glass-card rounded-[1.75rem] p-6">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-[color:var(--brand)] shadow-[0_12px_26px_rgba(7,27,58,0.07)]">
          <IconGlyph name={card.icon} />
        </div>
        <h3 class="font-black text-[color:var(--ink)]">{card.title}</h3>
        <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">{card.desc}</p>
      </article>
    ))}
  </div>
</section>
