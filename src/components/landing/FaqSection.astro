---
import IconGlyph from './IconGlyph.astro';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  faqs: FaqItem[];
  primaryCtaHref: string;
  primaryCtaLabel: string;
  ctaMicrocopy: string;
}

const { faqs, primaryCtaHref, primaryCtaLabel, ctaMicrocopy } = Astro.props;
---

<section id="faq" class="mx-auto max-w-[1240px] scroll-mt-28 px-4 py-14 md:px-6 md:py-18">
  <div class="text-xs font-black uppercase tracking-[0.22em] text-[color:var(--brand)]">Preguntas frecuentes</div>
  <div class="mt-8 grid gap-4 lg:grid-cols-5">
    {faqs.map((faq) => (
      <details class="group rounded-[1.5rem] border border-[color:var(--line)] bg-white p-5 shadow-[0_14px_30px_rgba(7,27,58,0.06)]">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 text-sm font-black text-[color:var(--ink)] marker:hidden">
          <span>{faq.q}</span>
          <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-[color:var(--page-bg-soft)] text-[color:var(--brand)] transition-transform group-open:rotate-45">+</span>
        </summary>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">{faq.a}</p>
      </details>
    ))}
  </div>

  <div class="mt-10 overflow-hidden rounded-[2rem] bg-[radial-gradient(circle_at_10%_10%,rgba(56,189,248,0.16),transparent_34%),linear-gradient(135deg,#071B3A,#0B1224)] p-6 text-white shadow-[0_28px_70px_rgba(7,27,58,0.22)] md:p-8">
    <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div class="flex gap-5">
        <div class="hidden h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-[rgba(11,92,255,0.95)] shadow-[0_20px_42px_rgba(11,92,255,0.28)] sm:flex">
          <IconGlyph name="gift" class="h-7 w-7" />
        </div>
        <div>
          <h2 class="text-2xl font-bold tracking-[-0.025em] md:text-4xl">
            Empieza con Nexuit completo por 7 días.
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300 md:text-base">
            Controla stock, ventas, empaque y conciliación sin tarjeta. Después elige el plan que necesita tu operación.
          </p>
        </div>
      </div>
      <div>
        <a
          href={primaryCtaHref}
          data-cta="final-trial"
          class="inline-flex w-full justify-center rounded-2xl bg-white px-8 py-4 text-sm font-black text-[color:var(--brand)] shadow-[0_18px_40px_rgba(255,255,255,0.12)] transition-transform duration-200 hover:-translate-y-0.5 md:w-auto"
        >
          {primaryCtaLabel}
        </a>
        <div class="mt-3 text-center text-xs font-medium text-slate-300">{ctaMicrocopy}</div>
      </div>
    </div>
  </div>
</section>
