---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  primaryCtaClass: string;
  secondaryCtaClass: string;
  registerUrl: string;
  loginUrl: string;
  faqs: FaqItem[];
}

const { primaryCtaClass, secondaryCtaClass, registerUrl, loginUrl, faqs } = Astro.props;
---

<section id="faq" class="mx-auto max-w-6xl scroll-mt-28 px-4 py-14">
  <div class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--brand)]">Plan y operación</div>
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[color:var(--ink)] md:text-4xl">
    Preguntas antes de empezar
  </h2>

  <div class="mt-8 grid gap-4 md:grid-cols-2">
    {faqs.map((faq) => (
      <details class="glass-card rounded-[1.75rem] p-6">
        <summary class="cursor-pointer text-sm font-semibold text-[color:var(--ink)]">{faq.q}</summary>
        <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{faq.a}</p>
      </details>
    ))}
  </div>

  <div class="mt-10 rounded-[2rem] border border-[rgba(255,255,255,0.1)] bg-[linear-gradient(135deg,#eff6ff_0%,#ffffff_38%,#eef2ff_100%)] p-8 shadow-[0_22px_50px_rgba(15,23,42,0.1)]">
    <div class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--brand)]">Cierre</div>
    <h3 class="mt-3 max-w-xl text-3xl font-semibold tracking-tight text-[color:var(--ink)]">
      Crea tu empresa y empieza con una estructura operativa clara.
    </h3>
    <p class="mt-4 max-w-2xl text-sm leading-7 text-[color:var(--muted)]">
      Ordena productos, sucursales, almacenes, POS, ventas y salidas desde el mismo inventario operativo.
    </p>
    <div class="mt-5 flex flex-wrap gap-2 text-[11px] font-medium uppercase tracking-[0.18em] text-[color:var(--muted)]">
      <span class="rounded-full border border-[color:var(--line)] bg-white/80 px-3 py-1">Multi-sucursal</span>
      <span class="rounded-full border border-[color:var(--line)] bg-white/80 px-3 py-1">POS disponible</span>
      <span class="rounded-full border border-[color:var(--line)] bg-white/80 px-3 py-1">Despachos conectados</span>
      <span class="rounded-full border border-[color:var(--line)] bg-white/80 px-3 py-1">Capacidades modulares</span>
    </div>
    <div class="mt-5 flex flex-col gap-3 sm:flex-row">
      <a href={registerUrl} data-cta="footer-create-company" class={primaryCtaClass}>
        Crear empresa
      </a>
      <a href={loginUrl} data-cta="footer-login" class={secondaryCtaClass}>
        Iniciar sesión
      </a>
    </div>
  </div>
</section>
