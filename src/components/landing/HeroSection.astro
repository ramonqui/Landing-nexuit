---
import IconGlyph from './IconGlyph.astro';

interface Props {
  chips: string[];
  primaryCtaHref: string;
  primaryCtaLabel: string;
  ctaMicrocopy: string;
}

const { chips, primaryCtaHref, primaryCtaLabel, ctaMicrocopy } = Astro.props;

const stats = [
  { label: 'Stock disponible', value: '1,240', note: 'productos', tone: 'text-[color:var(--ink)]', alert: false },
  { label: 'Ventas hoy', value: '$45,680', note: '12 pedidos', tone: 'text-[color:var(--ink)]', alert: false },
  { label: 'Pedidos por empacar', value: '28', note: 'en proceso', tone: 'text-[color:var(--ink)]', alert: false },
  { label: 'Diferencias de inventario', value: '-23', note: 'Atención', tone: 'text-[color:var(--danger)]', alert: true },
] as const;

const reconciliation = [
  { place: 'Almacén Norte', diff: '-4', tone: 'text-[color:var(--danger)]' },
  { place: 'Sucursal Centro', diff: '-7', tone: 'text-[color:var(--danger)]' },
  { place: 'Tienda Online', diff: '+2', tone: 'text-[color:var(--success)]' },
] as const;
---

<section class="mx-auto max-w-[1240px] px-4 pb-14 pt-10 md:px-6 md:pb-20 md:pt-16">
  <div class="grid items-center gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:gap-12">
    <div class="max-w-[41rem]">
      <div class="inline-flex rounded-full border border-[color:var(--line)] bg-white px-4 py-2 text-[11px] font-bold uppercase tracking-[0.14em] text-[color:var(--brand)] shadow-[0_10px_24px_rgba(7,27,58,0.05)]">
        TODO TU INVENTARIO. EN UNA SOLA BASE.
      </div>

      <h1 class="mt-6 max-w-[40rem] text-[2.55rem] font-bold leading-[1] tracking-[-0.035em] text-[color:var(--ink)] sm:text-5xl lg:max-w-none lg:text-[3.35rem] xl:text-[3.5rem]">
        <span class="lg:hidden">Controla stock, ventas y empaque sin perder mercancía.</span>
        <span class="hidden lg:block">
          <span class="block whitespace-nowrap">Controla stock, ventas</span>
          <span class="block whitespace-nowrap">y empaque sin perder</span>
          <span class="block whitespace-nowrap">mercancía.</span>
        </span>
      </h1>

      <p class="mt-5 max-w-lg text-[16px] leading-7 text-[color:var(--muted)] md:text-lg md:leading-8">
        Controla existencias, valida empaque y detecta diferencias antes de que se conviertan en pérdidas.
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:items-start">
        <a
          href={primaryCtaHref}
          data-cta="hero-trial"
          class="inline-flex w-full items-center justify-center rounded-2xl bg-[color:var(--brand)] px-7 py-3.5 text-base font-bold text-white shadow-[0_18px_34px_rgba(11,92,255,0.22)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[color:var(--brand-strong)] sm:w-auto"
        >
          {primaryCtaLabel}
        </a>
        <p class="text-sm font-semibold text-[color:var(--ink)] opacity-80">{ctaMicrocopy}</p>
      </div>

      <div class="mt-7 flex flex-wrap gap-2.5">
        {chips.map((chip, index) => (
          <div class="inline-flex items-center gap-2 rounded-full border border-[color:var(--line)] bg-white/80 px-3 py-2 text-sm font-semibold text-[color:var(--ink)] shadow-[0_10px_22px_rgba(7,27,58,0.04)]">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)]">
              <IconGlyph name={index === 0 ? 'warehouse' : index === 1 ? 'movement' : index === 2 ? 'box' : 'shield'} />
            </span>
            {chip}
          </div>
        ))}
      </div>
    </div>

    <div class="relative" aria-hidden="true">
      <div class="absolute inset-0 rounded-[3rem] bg-[radial-gradient(circle_at_30%_20%,rgba(56,189,248,0.22),transparent_38%),radial-gradient(circle_at_80%_12%,rgba(11,92,255,0.16),transparent_35%)] blur-2xl sm:-inset-6"></div>
      <div class="relative ml-auto max-w-[590px] overflow-hidden rounded-[2rem] border border-white/70 bg-white p-2 shadow-[0_30px_72px_rgba(7,27,58,0.16)]">
        <div class="overflow-hidden rounded-[1.6rem] bg-[color:var(--navy)] text-white">
          <div class="flex items-center justify-between border-b border-white/10 px-4 py-4 sm:px-5">
            <div class="flex items-center gap-2 text-sm font-bold">
              <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-[color:var(--brand)]">N</span>
              <span>NEXUIT</span>
            </div>
            <div class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-semibold text-slate-200">Operación de hoy</div>
          </div>

          <div class="bg-[linear-gradient(135deg,#ffffff,#f7fbff)] p-4 text-[color:var(--ink)] sm:p-5">
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-[color:var(--brand)]">Resumen general</div>
                <div class="mt-1 text-xl font-black text-[color:var(--ink)]">Inventario y ventas</div>
              </div>
              <div class="hidden rounded-2xl border border-[color:var(--line)] bg-white px-3 py-2 text-xs font-bold text-[color:var(--muted)] sm:block">Nexuit Store</div>
            </div>

            <div class="mt-5 grid grid-cols-2 gap-3 lg:grid-cols-4">
              {stats.map((stat) => (
                <div class={`rounded-2xl border p-3.5 ${stat.alert ? 'border-red-200 bg-red-50/80 shadow-[0_14px_28px_rgba(239,68,68,0.1)]' : 'border-[color:var(--line)] bg-white shadow-[0_10px_24px_rgba(7,27,58,0.05)]'}`}>
                  <div class="min-h-8 text-[11px] font-bold leading-4 text-[color:var(--muted)]">{stat.label}</div>
                  <div class={`mt-2 whitespace-nowrap text-[1.15rem] font-black leading-tight ${stat.tone}`}>{stat.value}</div>
                  <div class={`mt-1 text-[11px] font-semibold ${stat.alert ? 'text-[color:var(--danger)]' : 'text-[color:var(--muted)]'}`}>{stat.note}</div>
                </div>
              ))}
            </div>

            <div class="mt-4 grid gap-4 lg:grid-cols-[1.18fr_0.82fr]">
              <div class="rounded-3xl border border-[color:var(--line)] bg-white p-4 shadow-[0_14px_30px_rgba(7,27,58,0.05)]">
                <div class="text-sm font-black text-[color:var(--ink)]">Ventas de la semana</div>
                <svg class="mt-4 h-36 w-full overflow-visible" viewBox="0 0 420 180" role="img" aria-label="Gráfica visual de ventas de siete días">
                  <g stroke="#dce7f5" stroke-width="1">
                    <path d="M28 20H398" />
                    <path d="M28 60H398" />
                    <path d="M28 100H398" />
                    <path d="M28 140H398" />
                  </g>
                  <path d="M36 130 L92 86 L148 68 L204 42 L260 66 L316 78 L376 28" fill="none" stroke="#0B5CFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M36 130 L92 86 L148 68 L204 42 L260 66 L316 78 L376 28 L376 150 L36 150Z" fill="url(#heroChart)" opacity="0.22" />
                  <g fill="#0B5CFF">
                    {[36, 92, 148, 204, 260, 316, 376].map((x, index) => (
                      <circle cx={x} cy={[130, 86, 68, 42, 66, 78, 28][index]} r="5" />
                    ))}
                  </g>
                  <defs>
                    <linearGradient id="heroChart" x1="0" x2="0" y1="0" y2="1">
                      <stop stop-color="#0B5CFF" />
                      <stop offset="1" stop-color="#0B5CFF" stop-opacity="0" />
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <div class="rounded-3xl border border-[color:var(--line)] bg-white p-4 shadow-[0_14px_30px_rgba(7,27,58,0.05)]">
                <div class="text-sm font-black text-[color:var(--ink)]">Conciliación reciente</div>
                <div class="mt-3 grid gap-2.5">
                  {reconciliation.map((item) => (
                    <div class="flex items-center justify-between rounded-2xl border border-[color:var(--line)] bg-[color:var(--page-bg-soft)] px-3 py-2.5 text-sm">
                      <span class="font-semibold text-[color:var(--ink)]">{item.place}</span>
                      <span class={`font-black ${item.tone}`}>{item.diff}</span>
                    </div>
                  ))}
                </div>
                <div class="mt-3 rounded-2xl bg-[rgba(11,92,255,0.08)] px-4 py-2.5 text-center text-sm font-bold text-[color:var(--brand)]">
                  Ver diferencias
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
