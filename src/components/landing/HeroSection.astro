---
interface Props {
  primaryCtaClass: string;
  secondaryCtaClass: string;
  registerUrl: string;
  loginUrl: string;
}

const { primaryCtaClass, secondaryCtaClass, registerUrl, loginUrl } = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 pb-12 pt-10 md:pb-16 md:pt-20">
  <div class="grid items-center gap-10 md:grid-cols-2 md:gap-12">
    <div>
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.9)] px-4 py-1.5 text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted)] shadow-[0_8px_22px_rgba(148,163,184,0.12)] md:mb-5">
        <span class="font-semibold text-[color:var(--brand)]">Nexuit</span>
        <span class="text-[color:var(--accent)]">•</span>
        <span>Suite operativa SaaS</span>
      </div>

      <h1 class="max-w-2xl text-[2.65rem] font-semibold leading-[0.96] tracking-tight text-[color:var(--ink)] sm:text-5xl md:text-6xl">
        Ordena inventario, ventas y despachos en una suite multicanal.
      </h1>

      <p class="mt-4 max-w-xl text-[15px] leading-7 text-[color:var(--muted)] sm:text-base md:mt-5 md:text-lg md:leading-8">
        Nexuit conecta productos, sucursales, almacenes, POS, ventas físicas, tienda online y salidas
        para que cada canal opere sobre el mismo inventario.
      </p>

      <div class="mt-5 flex flex-col gap-3 sm:flex-row md:mt-6">
        <a href={registerUrl} data-cta="hero-create-company" class={primaryCtaClass}>
          Crear empresa
        </a>

        <a href={loginUrl} data-cta="hero-login" class={secondaryCtaClass}>
          Iniciar sesión
        </a>
      </div>

      <div class="mt-5 flex flex-wrap gap-2 md:mt-6">
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Multi-sucursal</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Multi-almacén</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">POS disponible</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Tienda online en evolución</span>
      </div>

      <div class="mt-6 grid max-w-lg grid-cols-3 gap-2 sm:gap-3 md:mt-8">
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-3 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)] sm:px-4">
          <div class="text-base font-semibold text-[color:var(--ink)] sm:text-lg">1 base</div>
          <div class="mt-1 text-[10px] uppercase tracking-[0.16em] text-[color:var(--muted)] sm:text-[11px] sm:tracking-[0.18em]">stock y ventas</div>
        </div>
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-3 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)] sm:px-4">
          <div class="text-base font-semibold text-[color:var(--ink)] sm:text-lg">POS</div>
          <div class="mt-1 text-[10px] uppercase tracking-[0.16em] text-[color:var(--muted)] sm:text-[11px] sm:tracking-[0.18em]">sin perder stock</div>
        </div>
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-3 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)] sm:px-4">
          <div class="text-base font-semibold text-[color:var(--ink)] sm:text-lg">Salidas</div>
          <div class="mt-1 text-[10px] uppercase tracking-[0.16em] text-[color:var(--muted)] sm:text-[11px] sm:tracking-[0.18em]">con contexto</div>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute inset-x-10 top-6 h-24 rounded-full bg-[rgba(37,99,235,0.22)] blur-3xl"></div>
      <div class="relative rounded-[2rem] border border-[rgba(255,255,255,0.7)] bg-[linear-gradient(145deg,rgba(15,23,42,0.98),rgba(30,41,59,0.96))] p-5 text-white shadow-[0_28px_70px_rgba(15,23,42,0.22)]">
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <div>
            <div class="text-xs uppercase tracking-[0.2em] text-slate-400">Vista general</div>
            <div class="mt-1 text-sm font-semibold text-white">Operación conectada</div>
          </div>
          <div class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-sky-300">Suite SaaS</div>
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-[1.2fr_0.8fr]">
          <div class="space-y-3">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Existencias</div>
                  <div class="mt-1 text-sm font-semibold text-white">Por almacén</div>
                </div>
                <div class="text-xs font-medium text-emerald-300">En línea</div>
              </div>
              <div class="mt-3 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-slate-400">Bodega</span><span class="font-semibold text-white">124</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">Sucursal</span><span class="font-semibold text-white">58</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">Reservado</span><span class="font-semibold text-white">12</span></div>
              </div>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Ventas conectadas</div>
              <div class="mt-1 text-sm font-semibold text-white">POS y venta online</div>
              <div class="mt-3 space-y-2">
                <div class="flex items-center justify-between rounded-2xl bg-[rgba(37,99,235,0.14)] px-3 py-2 text-xs">
                  <span class="text-slate-100">POS • Sucursal</span><span class="font-semibold text-sky-300">18</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl bg-[rgba(6,182,212,0.12)] px-3 py-2 text-xs">
                  <span class="text-slate-100">Online • Reservado</span><span class="font-semibold text-cyan-300">6</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl bg-white/6 px-3 py-2 text-xs">
                  <span class="text-slate-100">Despacho • Pendiente</span><span class="font-semibold text-white">4</span>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-3">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Variantes</div>
              <div class="mt-1 text-sm font-semibold text-white">Talla / Color</div>
              <div class="mt-3 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-slate-400">S • Negro</span><span class="font-semibold text-white">SKU-001</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">M • Negro</span><span class="font-semibold text-white">SKU-002</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">L • Negro</span><span class="font-semibold text-white">SKU-003</span></div>
              </div>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Salidas</div>
              <div class="mt-3 space-y-3">
                <div>
                  <div class="flex items-center justify-between text-[11px] text-slate-400">
                    <span>Picking</span>
                    <span>4 pedidos</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-white/8">
                    <div class="h-2 w-[72%] rounded-full bg-[linear-gradient(90deg,#38bdf8,#2563eb)]"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between text-[11px] text-slate-400">
                    <span>Packing</span>
                    <span>2 pedidos</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-white/8">
                    <div class="h-2 w-[42%] rounded-full bg-[linear-gradient(90deg,#22d3ee,#0ea5e9)]"></div>
                  </div>
                </div>
                <div class="rounded-2xl bg-white/6 px-3 py-2 text-[11px] text-slate-300">
                  Cada venta conserva sucursal, almacén, stock y salida operativa.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
