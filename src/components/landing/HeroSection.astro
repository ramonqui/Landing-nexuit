---
interface Props {
  primaryCtaClass: string;
  secondaryCtaClass: string;
}

const { primaryCtaClass, secondaryCtaClass } = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 pb-16 pt-12 md:pt-20">
  <div class="grid items-center gap-12 md:grid-cols-2">
    <div>
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.9)] px-4 py-1.5 text-[11px] tracking-[0.18em] text-[color:var(--muted)] uppercase shadow-[0_8px_22px_rgba(148,163,184,0.12)]">
        <span class="font-semibold text-[color:var(--brand)]">Nexuit Core</span>
        <span class="text-[color:var(--accent)]">•</span>
        <span>Inventario + Productos</span>
      </div>

      <h1 class="max-w-xl text-5xl font-semibold leading-[0.92] tracking-tight text-[color:var(--ink)] md:text-7xl">
        Inventario ordenado para fabricantes que quieren crecer sin perder el control
      </h1>

      <p class="mt-5 max-w-xl text-base leading-8 text-[color:var(--muted)] md:text-lg">
        Controla tu inventario físico aunque vendas en tienda o ecommerce. Evita sobreventa,
        errores de empaque y pérdidas por desorden en inventario.
      </p>

      <p class="mt-4 text-sm font-semibold text-[color:var(--brand)]">
        Plan inicial $199 MXN/mes
      </p>

      <p class="mt-3 text-sm text-[color:var(--muted)]">
        Usado en producción sin sobreventa.
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href="/signup" data-cta="hero-create-account" class={primaryCtaClass}>
          Crear cuenta por $199
        </a>

        <a href="#como-funciona" class={secondaryCtaClass}>
          Ver cómo funciona
        </a>
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Variantes reales + SKUs</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Inventario por ubicación</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Movimientos auditables</span>
        <span class="rounded-full border border-[color:var(--line)] bg-[rgba(255,255,255,0.74)] px-3 py-1 text-xs text-[color:var(--muted)]">Multi-negocio (multi-tenant)</span>
      </div>

      <div class="mt-8 grid max-w-lg grid-cols-3 gap-3">
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-4 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
          <div class="text-lg font-semibold text-[color:var(--ink)]">1 base</div>
          <div class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted)]">datos conectados</div>
        </div>
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-4 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
          <div class="text-lg font-semibold text-[color:var(--ink)]">+ control</div>
          <div class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted)]">por ubicación</div>
        </div>
        <div class="rounded-3xl border border-[color:var(--line)] bg-white/80 px-4 py-3 shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
          <div class="text-lg font-semibold text-[color:var(--ink)]">Listo</div>
          <div class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted)]">para escalar</div>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute inset-x-10 top-6 h-24 rounded-full bg-[rgba(37,99,235,0.22)] blur-3xl"></div>
      <div class="relative rounded-[2rem] border border-[rgba(255,255,255,0.7)] bg-[linear-gradient(145deg,rgba(15,23,42,0.98),rgba(30,41,59,0.96))] p-5 text-white shadow-[0_28px_70px_rgba(15,23,42,0.22)]">
        <div class="flex items-center justify-between border-b border-white/10 pb-4">
          <div>
            <div class="text-xs uppercase tracking-[0.2em] text-slate-400">Vista general</div>
            <div class="mt-1 text-sm font-semibold text-white">Dashboard</div>
          </div>
          <div class="rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-sky-300">Nexuit Core</div>
        </div>

        <div class="mt-4 grid gap-3 md:grid-cols-[1.2fr_0.8fr]">
          <div class="space-y-3">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Existencias</div>
                  <div class="mt-1 text-sm font-semibold text-white">Por almacén</div>
                </div>
                <div class="text-xs font-medium text-emerald-300">En línea</div>
              </div>
              <div class="mt-3 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-slate-400">Bodega</span><span class="font-semibold text-white">124</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">Sucursal</span><span class="font-semibold text-white">58</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">Reservado</span><span class="font-semibold text-white">12</span></div>
              </div>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Movimientos recientes</div>
              <div class="mt-1 text-sm font-semibold text-white">Historial auditable</div>
              <div class="mt-3 space-y-2">
                <div class="flex items-center justify-between rounded-2xl bg-[rgba(37,99,235,0.14)] px-3 py-2 text-xs">
                  <span class="text-slate-100">Entrada • Bodega</span><span class="font-semibold text-sky-300">+20</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl bg-[rgba(6,182,212,0.12)] px-3 py-2 text-xs">
                  <span class="text-slate-100">Transferencia • Bodega → Sucursal</span><span class="font-semibold text-cyan-300">-10</span>
                </div>
                <div class="flex items-center justify-between rounded-2xl bg-white/6 px-3 py-2 text-xs">
                  <span class="text-slate-100">Ajuste • Sucursal</span><span class="font-semibold text-white">-2</span>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-3">
            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Variantes</div>
              <div class="mt-1 text-sm font-semibold text-white">Talla / Color</div>
              <div class="mt-3 space-y-2">
                <div class="flex justify-between text-xs"><span class="text-slate-400">S • Negro</span><span class="font-semibold text-white">SKU-001</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">M • Negro</span><span class="font-semibold text-white">SKU-002</span></div>
                <div class="flex justify-between text-xs"><span class="text-slate-400">L • Negro</span><span class="font-semibold text-white">SKU-003</span></div>
              </div>
            </div>

            <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-400">Salud operativa</div>
              <div class="mt-3 space-y-3">
                <div>
                  <div class="flex items-center justify-between text-[11px] text-slate-400">
                    <span>Catálogo</span>
                    <span>98%</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-white/8">
                    <div class="h-2 w-[98%] rounded-full bg-[linear-gradient(90deg,#38bdf8,#2563eb)]"></div>
                  </div>
                </div>
                <div>
                  <div class="flex items-center justify-between text-[11px] text-slate-400">
                    <span>Inventario</span>
                    <span>92%</span>
                  </div>
                  <div class="mt-1 h-2 rounded-full bg-white/8">
                    <div class="h-2 w-[92%] rounded-full bg-[linear-gradient(90deg,#22d3ee,#0ea5e9)]"></div>
                  </div>
                </div>
                <div class="rounded-2xl bg-white/6 px-3 py-2 text-[11px] text-slate-300">
                  Una base limpia evita rehacer POS, ecommerce y marketplace después.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
