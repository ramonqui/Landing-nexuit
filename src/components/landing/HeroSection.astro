---
import IconGlyph from './IconGlyph.astro';

interface Props {
  chips: string[];
  primaryCtaHref: string;
  primaryCtaLabel: string;
  ctaMicrocopy: string;
}

const { chips, primaryCtaHref, primaryCtaLabel, ctaMicrocopy } = Astro.props;

const stats = [
  { label: 'Stock disponible', value: '1,240', note: 'productos', tone: 'text-[color:var(--ink)]' },
  { label: 'Ventas hoy', value: '$45,680', note: '12 pedidos', tone: 'text-[color:var(--ink)]' },
  { label: 'Pedidos por empacar', value: '28', note: 'en proceso', tone: 'text-[color:var(--ink)]' },
  { label: 'Diferencias de inventario', value: '-23', note: 'productos', tone: 'text-[color:var(--danger)]' },
] as const;

const reconciliation = [
  { place: 'Almacén Norte', diff: '-4', tone: 'text-[color:var(--danger)]' },
  { place: 'Sucursal Centro', diff: '-7', tone: 'text-[color:var(--danger)]' },
  { place: 'Tienda Online', diff: '+2', tone: 'text-[color:var(--success)]' },
] as const;
---

<section class="mx-auto max-w-[1240px] px-4 pb-14 pt-10 md:px-6 md:pb-20 md:pt-16">
  <div class="grid items-center gap-10 lg:grid-cols-[0.86fr_1.14fr] lg:gap-12">
    <div>
      <div class="inline-flex rounded-full border border-[color:var(--line)] bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.16em] text-[color:var(--brand)] shadow-[0_12px_28px_rgba(7,27,58,0.06)]">
        Todo tu inventario. En una sola base.
      </div>

      <h1 class="mt-6 max-w-2xl text-[2.75rem] font-black leading-[0.96] tracking-[-0.055em] text-[color:var(--ink)] sm:text-6xl lg:text-[4.2rem]">
        Controla stock, ventas y empaque sin perder mercancía.
      </h1>

      <p class="mt-5 max-w-xl text-[16px] leading-7 text-[color:var(--muted)] md:text-lg md:leading-8">
        Inventario en tiempo real, empaque validado y conciliación que explica cada diferencia.
      </p>

      <div class="mt-7 flex max-w-sm flex-col gap-3">
        <a
          href={primaryCtaHref}
          data-cta="hero-trial"
          class="inline-flex items-center justify-center rounded-2xl bg-[color:var(--brand)] px-6 py-3.5 text-base font-bold text-white shadow-[0_18px_34px_rgba(11,92,255,0.26)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[color:var(--brand-strong)]"
        >
          {primaryCtaLabel}
        </a>
        <p class="text-sm font-medium text-[color:var(--muted)]">{ctaMicrocopy}</p>
      </div>

      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:max-w-xl">
        {chips.map((chip, index) => (
          <div class="rounded-2xl border border-[color:var(--line)] bg-white/90 p-3 shadow-[0_12px_28px_rgba(7,27,58,0.06)]">
            <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-xl bg-[rgba(11,92,255,0.08)] text-[color:var(--brand)]">
              <IconGlyph name={index === 0 ? 'warehouse' : index === 1 ? 'movement' : index === 2 ? 'box' : 'shield'} />
            </div>
            <div class="text-sm font-bold leading-snug text-[color:var(--ink)]">{chip}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative" aria-hidden="true">
      <div class="absolute inset-0 rounded-[3rem] bg-[radial-gradient(circle_at_30%_20%,rgba(56,189,248,0.22),transparent_38%),radial-gradient(circle_at_80%_12%,rgba(11,92,255,0.16),transparent_35%)] blur-2xl sm:-inset-6"></div>
      <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-white p-2 shadow-[0_32px_80px_rgba(7,27,58,0.17)]">
        <div class="grid min-h-[29rem] overflow-hidden rounded-[1.6rem] bg-white text-[color:var(--ink)] md:grid-cols-[13rem_1fr]">
          <aside class="hidden bg-[color:var(--navy)] p-5 text-white md:block">
            <div class="flex items-center gap-2 text-sm font-bold">
              <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[color:var(--brand)]">N</span>
              NEXUIT
            </div>
            <nav class="mt-8 grid gap-2 text-xs text-slate-300">
              {['Resumen', 'Inventario', 'Ventas', 'Pedidos', 'Empaque', 'Conciliación', 'Reportes'].map((item, index) => (
                <div class={`rounded-xl px-3 py-2 ${index === 0 ? 'bg-[color:var(--brand)] text-white' : 'bg-white/0'}`}>
                  {item}
                </div>
              ))}
            </nav>
          </aside>

          <div class="bg-[linear-gradient(135deg,#ffffff,#f7fbff)] p-4 sm:p-6">
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="text-[11px] font-bold uppercase tracking-[0.18em] text-[color:var(--brand)]">Resumen general</div>
                <div class="mt-1 text-lg font-black text-[color:var(--ink)]">Operación de hoy</div>
              </div>
              <div class="rounded-2xl border border-[color:var(--line)] bg-white px-3 py-2 text-xs font-bold text-[color:var(--muted)]">
                Nexuit Store
              </div>
            </div>

            <div class="mt-5 grid grid-cols-2 gap-3 xl:grid-cols-4">
              {stats.map((stat) => (
                <div class="rounded-2xl border border-[color:var(--line)] bg-white p-4 shadow-[0_12px_28px_rgba(7,27,58,0.06)]">
                  <div class="text-[11px] font-semibold text-[color:var(--muted)]">{stat.label}</div>
                  <div class={`mt-3 text-2xl font-black ${stat.tone}`}>{stat.value}</div>
                  <div class="mt-1 text-[11px] text-[color:var(--muted)]">{stat.note}</div>
                </div>
              ))}
            </div>

            <div class="mt-4 grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
              <div class="rounded-3xl border border-[color:var(--line)] bg-white p-5 shadow-[0_16px_34px_rgba(7,27,58,0.06)]">
                <div class="text-sm font-black text-[color:var(--ink)]">Ventas de los últimos 7 días</div>
                <svg class="mt-5 h-44 w-full overflow-visible" viewBox="0 0 420 180" role="img" aria-label="Gráfica visual de ventas de siete días">
                  <g stroke="#dce7f5" stroke-width="1">
                    <path d="M28 20H398" />
                    <path d="M28 60H398" />
                    <path d="M28 100H398" />
                    <path d="M28 140H398" />
                  </g>
                  <path d="M36 130 L92 86 L148 68 L204 42 L260 66 L316 78 L376 28" fill="none" stroke="#0B5CFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M36 130 L92 86 L148 68 L204 42 L260 66 L316 78 L376 28 L376 150 L36 150Z" fill="url(#heroChart)" opacity="0.22" />
                  <g fill="#0B5CFF">
                    {[36, 92, 148, 204, 260, 316, 376].map((x, index) => (
                      <circle cx={x} cy={[130, 86, 68, 42, 66, 78, 28][index]} r="5" />
                    ))}
                  </g>
                  <defs>
                    <linearGradient id="heroChart" x1="0" x2="0" y1="0" y2="1">
                      <stop stop-color="#0B5CFF" />
                      <stop offset="1" stop-color="#0B5CFF" stop-opacity="0" />
                    </linearGradient>
                  </defs>
                </svg>
              </div>

              <div class="rounded-3xl border border-[color:var(--line)] bg-white p-5 shadow-[0_16px_34px_rgba(7,27,58,0.06)]">
                <div class="text-sm font-black text-[color:var(--ink)]">Conciliación reciente</div>
                <div class="mt-4 grid gap-3">
                  {reconciliation.map((item) => (
                    <div class="flex items-center justify-between rounded-2xl border border-[color:var(--line)] bg-[color:var(--page-bg-soft)] px-3 py-3 text-sm">
                      <span class="font-semibold text-[color:var(--ink)]">{item.place}</span>
                      <span class={`font-black ${item.tone}`}>{item.diff} diferencia</span>
                    </div>
                  ))}
                </div>
                <div class="mt-4 rounded-2xl bg-[rgba(11,92,255,0.08)] px-4 py-3 text-center text-sm font-bold text-[color:var(--brand)]">
                  Ver diferencias
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
