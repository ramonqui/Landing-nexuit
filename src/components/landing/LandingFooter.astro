---
import BrandMark from './BrandMark.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: NavItem[];
}

const { navItems } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--line)] bg-white/80">
  <div class="mx-auto grid max-w-[1240px] gap-8 px-4 py-8 text-sm text-[color:var(--muted)] md:grid-cols-[1fr_auto] md:items-center md:px-6">
    <div class="flex items-start gap-3">
      <BrandMark />
      <div>
        <div class="font-black tracking-[0.03em] text-[color:var(--ink)]">NEXUIT</div>
        <p class="mt-1">Tu operación conectada. Mejor visibilidad de tu mercancía.</p>
      </div>
    </div>

    <div class="flex flex-wrap gap-x-5 gap-y-3 md:justify-end">
      {navItems.map((item) => (
        <a class="transition-colors hover:text-[color:var(--ink)]" href={item.href}>{item.label}</a>
      ))}
      <a class="transition-colors hover:text-[color:var(--ink)]" href="/terminos">Términos</a>
      <a class="transition-colors hover:text-[color:var(--ink)]" href="/privacidad">Privacidad</a>
    </div>
  </div>
  <div class="mx-auto flex max-w-[1240px] flex-col gap-3 border-t border-[color:var(--line)] px-4 py-5 text-xs text-[color:var(--muted)] md:flex-row md:items-center md:justify-between md:px-6">
    <span>© {year} Nexuit. Todos los derechos reservados.</span>
    <span>Inventario, ventas, empaque y conciliación en una sola base.</span>
  </div>
</footer>
